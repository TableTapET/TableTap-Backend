[run]
branch = True
source =
    apps
omit =
    */migrations/*
    */tests/*
    */test_*.py
    */__init__.py
    */settings/*
    manage.py
    */asgi.py
    */wsgi.py

[report]
precision = 2
show_missing = True
skip_covered = True
fail_under = 80

exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if __name__ == "__main__":

[html]
directory = coverage_html_report
title = TableTap Backend Coverage

[xml]
output = coverage.xml